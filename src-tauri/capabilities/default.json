{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:allow-save",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "semgrep", "cmd": "semgrep", "args": true }]
    }
  ]
}
